#!/bin/sh

# Generate vectors.S, the trap/interrupt entry points.
# There has to be one entry point per interrupt number
# since otherwise there's no way for trap() to discover
# the interrupt number.

printf "# generated by the script 'vectors' - do not edit\n"
printf "# handlers\n"
printf ".globl alltraps\n"
for i in {0..256}
do
	printf ".globl vector$i\n"
	printf "vector$i:\n"
	if [ "$i" -ne 8 ] && [ "$i" -lt 10 -o "$i" -gt 14 ] && [ "$i" -ne 17 ]; then
		printf "	pushl \$0\n"
	fi
	printf "	pushl \$$i\n"
	printf "	jmp alltraps\n"
done

printf "\n# vector table\n"
printf ".data\n"
printf ".globl vectors\n"
printf "vectors:\n"
for i in {0..256}
do
	printf "	.long vector$i\n"
done